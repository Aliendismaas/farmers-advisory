# ─── Advisory content strings (advisory.py) ───
msgid "This month falls within the typical planting window for your zone."
msgstr "Mwezi huu uko ndani ya kipindi cha kawaida cha kupanda kwa eneo lako."

msgid "Typical planting months for this crop in your zone do not include the current month (%(month)s). Check again closer to the season."
msgstr "Miezi ya kawaida ya kupanda zao hili katika eneo lako haijumuishi mwezi wa sasa (%(month)s). Angalia tena karibu na msimu."

msgid "This month is within the typical harvest period for this crop in your zone."
msgstr "Mwezi huu uko ndani ya kipindi cha kawaida cha kuvuna zao hili katika eneo lako."

msgid "Peak harvest months for this crop differ from the current month; this is a general calendar guide only."
msgstr "Miezi ya kilele cha uvunaji wa zao hili inatofautiana na mwezi wa sasa; hii ni mwongozo wa kalenda tu."

msgid "Next ~14 days include %(days)s day(s) with cold lows (frost risk possible); delay sensitive planting if unsure."
msgstr "Siku ~14 zijazo zina %(days)s siku zenye baridi kali (hatari ya theluji inawezekana); kuchelewa kupanda mazao nyeti ikiwa una shaka."

msgid "%(days)s hot day(s) forecast; ensure irrigation if planting or flowering."
msgstr "%(days)s siku za joto zinatabiriwa; hakikisha umwagiliaji ikiwa unapanda au mazao yanachanua."

msgid "Heavy rain possible on %(days)s day(s); consider soil drainage before planting."
msgstr "Mvua kubwa inawezekana siku %(days)s; fikiria mifereji ya udongo kabla ya kupanda."

msgid "Weather outlook shows repeated cold nights; treat as marginal."
msgstr "Hali ya hewa inaonyesha usiku wa baridi mara kwa mara; ichukulie kama ya hatarini."

msgid "Sustained heat in the forecast; irrigate and avoid heat-stress windows if possible."
msgstr "Joto la kudumu linatabiriwa; mwagilia na epuka nyakati za msongo wa joto ikiwezekana."
