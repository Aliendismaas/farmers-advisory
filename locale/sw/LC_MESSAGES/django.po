# ─── Advisory detail text (from advisory.py) ───
msgid "This month falls within the typical planting window for your zone."
msgstr "Mwezi huu uko ndani ya muda wa kawaida wa kupanda kwa eneo lako."

msgid "Typical planting months for this crop in your zone do not include the current month (%(month)s). Check again closer to the season."
msgstr "Miezi ya kawaida ya kupanda zao hili katika eneo lako haijumuishi mwezi huu (%(month)s). Angalia tena ukikaribia msimu."

msgid "This month is within the typical harvest period for this crop in your zone."
msgstr "Mwezi huu uko ndani ya kipindi cha kawaida cha kuvuna zao hili katika eneo lako."

msgid "Peak harvest months for this crop differ from the current month; this is a general calendar guide only."
msgstr "Miezi ya mavuno ya zao hili ni tofauti na mwezi huu; hii ni mwongozo wa kalenda tu."

msgid "Next ~14 days include %(days)s day(s) with cold lows (frost risk possible); delay sensitive planting if unsure."
msgstr "Siku ~14 zijazo zina siku %(days)s zenye baridi kali (hatari ya theluji inawezekana); chelewesha kupanda mazao nyepesi ukiwa na wasiwasi."

msgid "%(days)s hot day(s) forecast; ensure irrigation if planting or flowering."
msgstr "Siku %(days)s za joto zimetabiriwa; hakikisha kumwagilia maji ukipanda au ukichanua."

msgid "Heavy rain possible on %(days)s day(s); consider soil drainage before planting."
msgstr "Mvua kubwa inawezekana katika siku %(days)s; fikiria mifereji ya udongo kabla ya kupanda."

msgid "Weather outlook shows repeated cold nights; treat as marginal."
msgstr "Hali ya hewa inaonyesha usiku wa baridi mara kwa mara; chukulia kama wakati wa kando."

msgid "Sustained heat in the forecast; irrigate and avoid heat-stress windows if possible."
msgstr "Joto la muda mrefu limetabiriwa; mwagilia maji na epuka nyakati za msongo wa joto ikiwezekana."

# ─── Advisory Preference page ───
msgid "Advisory Preference"
msgstr "Aina ya Ushauri"

msgid "What advisories do you want?"
msgstr "Unataka ushauri gani?"

msgid "Choose the type of farming guidance you'd like to receive on your dashboard and by SMS."
msgstr "Chagua aina ya mwongozo wa kilimo ambao ungependa kupokea kwenye dashibodi yako na kwa SMS."

msgid "You can change this at any time from your profile settings."
msgstr "Unaweza kubadilisha hili wakati wowote kutoka mipangilio ya wasifu wako."

msgid "Planting Advisory"
msgstr "Ushauri wa Kupanda"

msgid "Get guidance on the best time to plant your crops — ideal windows, soil prep, weather risks before and during planting."
msgstr "Pata mwongozo wa wakati bora wa kupanda mazao yako — muda mzuri, maandalizi ya udongo, hatari za hali ya hewa kabla na wakati wa kupanda."

msgid "Harvest Advisory"
msgstr "Ushauri wa Kuvuna"

msgid "Know when your crops are ready to harvest and get alerts about weather that could damage your yield at harvest time."
msgstr "Jua wakati mazao yako yako tayari kuvunwa na upate tahadhari za hali ya hewa inayoweza kudhuru mavuno yako."

msgid "Both — Full Advisory"
msgstr "Yote Mawili — Ushauri Kamili"

msgid "Receive complete guidance covering both planting and harvest windows for all your crops."
msgstr "Pata mwongozo kamili unaojumuisha muda wa kupanda na kuvuna kwa mazao yako yote."

msgid "Save & Go to Dashboard"
msgstr "Hifadhi na Nenda Dashibodini"

msgid "You can update this preference anytime from Profile Settings."
msgstr "Unaweza kusasisha chaguo hili wakati wowote kutoka Mipangilio ya Wasifu."

# ─── Notification Preferences page ───
msgid "Notification Preferences"
msgstr "Mipangilio ya Arifa"

msgid "Choose how weather and advisory alerts should reach you."
msgstr "Chagua jinsi tahadhari za hali ya hewa na ushauri zinavyopaswa kukufikia."

msgid "Live Preview"
msgstr "Muonekano wa Moja kwa Moja"

msgid "SMS Alerts"
msgstr "Tahadhari za SMS"

msgid "Text messages to your phone"
msgstr "Ujumbe wa maandishi kwenye simu yako"

msgid "Emergency Alerts Only"
msgstr "Tahadhari za Dharura Peke Yake"

msgid "Only critical weather warnings"
msgstr "Tahadhari muhimu za hali ya hewa peke yake"

msgid "Voice Alerts"
msgstr "Tahadhari za Sauti"

msgid "Spoken alerts via phone call"
msgstr "Tahadhari za kusemwa kwa simu"

msgid "Receive text messages for planting reminders, weather warnings, and harvest advisories directly on your phone."
msgstr "Pokea ujumbe wa maandishi wa kukumbusha kupanda, tahadhari za hali ya hewa, na ushauri wa kuvuna moja kwa moja kwenye simu yako."

msgid "Only get notified for critical weather events like storms, frost, or extreme heat. Routine advisories will be silenced."
msgstr "Pata arifa tu kwa matukio muhimu ya hali ya hewa kama dhoruba, theluji, au joto kali. Ushauri wa kawaida utanyamazishwa."

msgid "Get spoken alerts via phone call for urgent advisories. Useful when you're out in the field and can't check text messages."
msgstr "Pata tahadhari za kusemwa kwa simu kwa ushauri wa haraka. Muhimu unapokuwa shambani na huwezi kuangalia ujumbe."

msgid "Off"
msgstr "Zima"

msgid "On"
msgstr "Washa"

msgid "Your preferences are saved securely and used only for advisory notifications."
msgstr "Mipangilio yako imehifadhiwa salama na inatumika tu kwa arifa za ushauri."

msgid "Save Preferences"
msgstr "Hifadhi Mipangilio"

